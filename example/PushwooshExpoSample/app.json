{
  "expo": {
    "name": "Pushwoosh Expo Sample",
    "slug": "pushwoosh-expo-sample",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pushwoosh.sample"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pushwoosh.sample",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "pushwoosh-expo-plugin",
        {
          "mode": "development",
          "android": {
            "apiToken": "YOUR_PUSHWOOSH_API_TOKEN",
            "logLevel": "DEBUG"
          },
          "ios": {
            "PW_API_TOKEN": "YOUR_PUSHWOOSH_API_TOKEN",
            "Pushwoosh_LOG_LEVEL": "DEBUG"
          }
        }
      ]
    ]
  }
}
